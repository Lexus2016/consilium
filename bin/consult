#!/usr/bin/env bash
#
# consult — the universal adapter for consilium, a cross-agent consultation bus.
#
# Ask one AI coding CLI (the advisor) a question in headless mode, print the
# answer, and save a transcript. Symmetric: any agent can call this, so any
# agent can be the hub or the advisor.
#
# Target shell: macOS bash 3.2. No associative arrays; empty arrays are expanded
# with the ${arr[@]+...} guard so `set -u` does not trip on them.

set -euo pipefail

VERSION="0.7.2"
PROG="consult"

AGENTS="claude agy hermes opencode codex grok pi cursor kilo cline goose kimi"
PREAMBLE="You are a peer AI advisor consulted by another agent. Give honest, direct analysis. Advice only — do not modify, create, or delete files. Reply with your written analysis as plain text — that written answer is the entire deliverable."
# Used by --review. Deliberately adversarial: a reviewer told to 'assess quality'
# rubber-stamps; a reviewer told to 'find where the RESULT fails the TASK' catches
# real defects. The PASS/FAIL verdict makes the answer actionable for the hub.
REVIEW_PREAMBLE="You are a peer AI advisor doing an ADVERSARIAL review for another agent. You are given a TASK (the question, plus any ## Context) and a RESULT to judge (a diff or files under ## Input, and/or the working directory). Find every place the RESULT does NOT satisfy the TASK, plus bugs, missing edge cases, and weaknesses. Do not rubber-stamp; if it is fine, say so, but only after a genuine search. Be concrete: cite the exact location and explain what is wrong and why. Finish with a line 'VERDICT: PASS' or 'VERDICT: FAIL' followed by a short, ranked list of the most important issues. Advice only — do not modify, create, or delete files."

LOG_DIR="${CONSILIUM_LOG_DIR:-$HOME/.consilium/log}"

err()  { printf '%s: %s\n' "$PROG" "$*" >&2; }
warn() { printf '%s: warning: %s\n' "$PROG" "$*" >&2; }

usage() {
  cat <<EOF
$PROG — consult another AI coding agent for a second opinion.

usage:
  $PROG <agent> [options] -- <question...>
  $PROG <agent> [options] "<question>"
  $PROG --panel <a,b,c> [options] -- <question...>
  $PROG council -f <file> [-f <file>...] -q <question>
  <command> | $PROG <agent> [options] -- <question...>

agents:
  claude | agy | hermes | opencode | codex | grok | pi | cursor | kilo | cline | goose | kimi

council (needs python3):
  $PROG council audits CODE with a multi-agent panel (different providers),
  synthesizes one answer, and verifies every finding against its file:line.
  EXPENSIVE (~minutes, several paid calls) — high-stakes code questions only.

options:
  --panel LIST     ask several advisors in parallel (comma-separated), each
                   independently, then print all answers back-to-back
  --context FILE   inline a context file into the prompt
  --code DIR       give the advisor a working directory for code context
  --model NAME     override the model, for agents that accept one
  --continue       continue the advisor's previous session
  --review         use an adversarial review preamble: judge the RESULT
                   (piped diff / --context / --code) against the TASK in the
                   question, hunt for mismatches and bugs, end with PASS/FAIL
  --raw            send the question as-is (no advisor preamble)
  --no-log         do not write a transcript
  --list           list agents and whether each is installed
  -h, --help       show this help
  --version        show version

stdin:
  if you pipe text in (e.g. \`git diff | $PROG ...\`) it is added to the
  prompt under an "## Input" heading, so the advisor sees it as the material
  to review. The advisor's own stdin is closed; only the hub reads the pipe.

env:
  CONSILIUM_LOG_DIR   transcript directory (default: ~/.consilium/log)
  CONSILIUM_TIMEOUT   per-call timeout, if 'timeout'/'gtimeout' is available
  CONSILIUM_MAX_DEPTH consultation-chain depth limit (default: 3)
  CONSILIUM_LOG_KEEP  keep only the newest N transcripts (default: 200; 0 = all)
  CONSILIUM_RETRY_EMPTY  retry an advisor that exits 0 with a blank answer, up to
                     N times (default: 1; 0 = never). agy/grok are agentic CLIs
                     whose headless turn occasionally ends with no text.

examples:
  $PROG codex -- "Is a read-only sandbox enough to make a consultant safe?"
  $PROG opencode --context design.md -- "Any race conditions in this plan?"
  $PROG claude --code . -- "Spot bugs in the auth flow"
  $PROG --panel agy,opencode,codex -- "Is this migration safe to run twice?"
  git diff | $PROG codex -- "Review these changes for bugs"
  git diff | $PROG --panel codex,agy --review -- "Task: add rate limiting to the login route"
EOF
}

is_known_agent() {
  case " $AGENTS " in
    *" $1 "*) return 0 ;;
    *)        return 1 ;;
  esac
}

# Map an advisor NAME to the actual binary on PATH. Identity for every agent
# except `cursor`: the Cursor CLI installs as `cursor-agent` (and, on newer
# builds, exposes a bare `agent` alias), so resolve to whichever exists. This is
# the ONLY place a roster name and its binary diverge; keep it that way.
agent_bin() {
  case "$1" in
    cursor)
      if command -v cursor-agent >/dev/null 2>&1; then printf 'cursor-agent'
      else printf 'agent'; fi ;;
    *) printf '%s' "$1" ;;
  esac
}

list_agents() {
  local a path
  for a in $AGENTS; do
    if path="$(command -v "$(agent_bin "$a")" 2>/dev/null)"; then
      printf '  %-9s installed  (%s)\n' "$a" "$path"
    else
      printf '  %-9s not found\n' "$a"
    fi
  done
}

# ----- argument parsing ------------------------------------------------------

agent=""
panel=""
context_file=""
code_dir=""
model=""
do_continue=0
raw=0
review=0
no_log=0
question=""

# How to re-invoke ourselves for --panel children. Prefer the installed
# `consult` (a PATH symlink that points back here), so a panel works the same
# whether the parent ran from PATH or as ./bin/consult; fall back to $0.
if command -v consult >/dev/null 2>&1; then
  SELF="consult"
else
  SELF="$0"
fi

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 2
fi

# Council mode: `consult council [-f FILE]... -q "Q"` runs the multi-agent council
# (Python) instead of a single advisor. Intercepted BEFORE the option parser so
# the council's own flags (-f/-q) are handled by the council CLI, not consult.
# No recursion: council members are spawned as `consult agy|opencode|hermes`.
if [ "${1:-}" = "council" ]; then
  shift
  subcmd="audit"
  case "${1:-}" in
    check|audit) subcmd="$1"; shift ;;
  esac
  _t="$0"; [ -L "$_t" ] && _t="$(readlink "$_t")"
  _root="$(cd "$(dirname "$_t")/.." && pwd)"
  if ! command -v python3 >/dev/null 2>&1; then
    err "council mode needs python3 on PATH"; exit 127
  fi
  if [ ! -f "$_root/council/__main__.py" ]; then
    err "council mode needs the consilium repo, but the 'council' package was not found next to consult ($_root/council). A --copy install cannot run council — symlink-install with ./install.sh, or run 'consult council' from the repo checkout."
    exit 127
  fi
  exec env PYTHONPATH="$_root${PYTHONPATH:+:$PYTHONPATH}" \
           COUNCIL_CONFIG="${COUNCIL_CONFIG:-$_root/config/council.json}" \
           COUNCIL_CONSULT_BIN="${COUNCIL_CONSULT_BIN:-$_root/bin/consult}" \
           python3 -m council "$subcmd" "$@"
fi

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)    usage; exit 0 ;;
    --version)    printf 'consilium %s %s\n' "$PROG" "$VERSION"; exit 0 ;;
    --list)       list_agents; exit 0 ;;
    --context)    [ "$#" -ge 2 ] || { err "option --context needs a value"; exit 2; }; context_file="$2"; shift 2 ;;
    --context=*)  context_file="${1#*=}"; shift ;;
    --code)       [ "$#" -ge 2 ] || { err "option --code needs a value"; exit 2; }; code_dir="$2"; shift 2 ;;
    --code=*)     code_dir="${1#*=}"; shift ;;
    --panel)      [ "$#" -ge 2 ] || { err "option --panel needs a value"; exit 2; }; panel="$2"; shift 2 ;;
    --panel=*)    panel="${1#*=}"; shift ;;
    --model)      [ "$#" -ge 2 ] || { err "option --model needs a value"; exit 2; }; model="$2"; shift 2 ;;
    --model=*)    model="${1#*=}"; shift ;;
    --continue)   do_continue=1; shift ;;
    --raw)        raw=1; shift ;;
    --review)     review=1; shift ;;
    --no-log)     no_log=1; shift ;;
    --)           shift; question="$*"; break ;;
    -*)           err "unknown option: $1"; usage >&2; exit 2 ;;
    *)
      if [ -z "$agent" ]; then
        agent="$1"; shift
      else
        question="$*"; break
      fi
      ;;
  esac
done

# ----- validation ------------------------------------------------------------

if [ -z "$question" ]; then
  err "no question given"; usage >&2; exit 2
fi
if [ -n "$context_file" ] && [ ! -f "$context_file" ]; then
  err "context file not found: $context_file"; exit 2
fi
if [ -n "$code_dir" ] && [ ! -d "$code_dir" ]; then
  err "code dir not found: $code_dir"; exit 2
fi
# Refuse a flag-like --model value: it is forwarded as a token to the advisor CLI,
# so a value beginning with '-' could inject an unintended (e.g. permission-
# granting) flag. Real model names never start with '-'.
case "$model" in
  -*) err "--model value must not begin with '-' (got '$model')"; exit 2 ;;
esac

# panel_agents is the resolved, validated list for --panel mode; empty in
# single-advisor mode.
panel_agents=""
if [ -n "$panel" ]; then
  if [ -n "$agent" ]; then
    err "use either <agent> or --panel, not both"; exit 2
  fi
  # comma-separated -> space-separated, keeping only known + installed advisors,
  # de-duplicated, order preserved. `set -f` while splitting so a panel value like
  # '*' is NOT pathname-expanded against the CWD (the unquoted command substitution
  # would otherwise turn '*' into filenames, some of which could match an agent name).
  set -f
  for a in $(printf '%s' "$panel" | tr ',' ' '); do
    if ! is_known_agent "$a"; then
      warn "panel: unknown agent '$a' (expected one of: $AGENTS); skipping"; continue
    fi
    if ! command -v "$(agent_bin "$a")" >/dev/null 2>&1; then
      warn "panel: agent '$a' is not installed or not on PATH; skipping"; continue
    fi
    case " $panel_agents " in *" $a "*) ;; *) panel_agents="$panel_agents $a" ;; esac
  done
  set +f
  panel_agents="${panel_agents# }"
  if [ -z "$panel_agents" ]; then
    err "panel: no usable advisors in '$panel'"; exit 2
  fi
else
  if [ -z "$agent" ]; then
    err "no agent given"; usage >&2; exit 2
  fi
  if ! is_known_agent "$agent"; then
    err "unknown agent: $agent (expected one of: $AGENTS)"; exit 2
  fi
  if ! command -v "$(agent_bin "$agent")" >/dev/null 2>&1; then
    err "agent '$agent' is not installed or not on PATH"; exit 127
  fi
fi

# ----- recursion guard -------------------------------------------------------
# Stop A -> B -> A consultation loops from burning tokens. Each call bumps
# CONSILIUM_CALL_DEPTH in the environment the advisor inherits; abort past max.
depth="${CONSILIUM_CALL_DEPTH:-0}"
max_depth="${CONSILIUM_MAX_DEPTH:-3}"
case "$depth" in ""|*[!0-9]*) depth=0 ;; esac
case "$max_depth" in ""|*[!0-9]*) max_depth=3 ;; esac
if [ "$depth" -ge "$max_depth" ]; then
  err "consultation depth limit reached (depth=$depth, max=$max_depth); aborting to prevent a consult loop"
  exit 3
fi
export CONSILIUM_CALL_DEPTH=$((depth + 1))

# ----- piped stdin -----------------------------------------------------------
# If text was piped in, read it ONCE here in the hub; it becomes review material
# in the prompt (## Input). Every advisor is exec'd with </dev/null, so the hub
# is the only thing that ever consumes the pipe.
#
# Read ONLY when stdin is a real pipe (`cmd | consult`) or a redirected file
# (`consult < file`). A bare terminal, /dev/null, or a closed/socket stdin (how
# most non-interactive launchers wire it) must NOT trigger a read, or `cat`
# would block forever waiting for an EOF that never comes.
stdin_content=""
if [ -p /dev/stdin ] || { [ ! -t 0 ] && [ -f /dev/stdin ]; }; then
  stdin_content="$(cat)" || stdin_content=""
fi

# ----- panel mode: fan out to several advisors in parallel -------------------
# Each advisor is a plain recursive `consult` call, so it reuses ALL of the
# dispatch / timeout / logging logic below and writes its own transcript. The
# advisors never see each other's answers — independence is the point; the hub
# synthesizes. Children inherit CONSILIUM_CALL_DEPTH+1, so the depth guard still
# bounds any onward consulting.
if [ -n "$panel_agents" ]; then
  # Build one effective context file for the children: optional user --context
  # plus optional piped stdin, merged once (children are separate processes and
  # cannot read this hub's already-consumed stdin).
  panel_ctx=""
  panel_ctx_tmp=""
  if [ -n "$stdin_content" ]; then
    panel_ctx_tmp="$(mktemp "${TMPDIR:-/tmp}/consilium-panelctx.XXXXXX")"
    {
      if [ -n "$context_file" ]; then cat "$context_file"; printf '\n'; fi
      printf '%s\n' "$stdin_content"
    } > "$panel_ctx_tmp"
    panel_ctx="$panel_ctx_tmp"
  elif [ -n "$context_file" ]; then
    panel_ctx="$context_file"
  fi

  paneldir="$(mktemp -d "${TMPDIR:-/tmp}/consilium-panel.XXXXXX")"
  pids=""
  # On interrupt, tear down the panel children AND their process groups so a
  # Ctrl-C / SIGTERM does not leave paid advisor processes running. `-$_pp` (a
  # negative pid) targets the child's whole process group when it is a group
  # leader (spawned via setsid below); the fallback signals the direct child.
  trap 'for _pp in $pids; do kill -TERM "-$_pp" 2>/dev/null || kill -TERM "$_pp" 2>/dev/null || true; done; exit 130' INT TERM
  idx=0
  for a in $panel_agents; do
    idx=$((idx + 1))
    out="$paneldir/$(printf '%03d' "$idx")-$a.out"
    err="$paneldir/$(printf '%03d' "$idx")-$a.err"
    (
      child=("$SELF" "$a")
      [ -n "$panel_ctx" ]      && child+=(--context "$panel_ctx")
      [ -n "$code_dir" ]       && child+=(--code "$code_dir")
      [ -n "$model" ]          && child+=(--model "$model")
      [ "$do_continue" -eq 1 ] && child+=(--continue)
      [ "$raw" -eq 1 ]         && child+=(--raw)
      [ "$review" -eq 1 ]      && child+=(--review)
      [ "$no_log" -eq 1 ]      && child+=(--no-log)
      child+=(-- "$question")
      # Make this child its own process-group leader so the trap can kill the whole
      # child tree (nested consult + advisor grandchild) as a unit; exec so $! is
      # that leader. Prefer setsid; fall back to a one-line perl setsid (stock macOS
      # has no setsid but does have perl); last resort exec directly (Ctrl-C still
      # reaches the tree via the shared terminal group).
      if command -v setsid >/dev/null 2>&1; then
        exec setsid "${child[@]}"
      elif command -v perl >/dev/null 2>&1; then
        exec perl -e 'use POSIX qw(setsid); setsid(); exec { $ARGV[0] } @ARGV; POSIX::_exit(127)' -- "${child[@]}"
      else
        exec "${child[@]}"
      fi
    ) >"$out" 2>"$err" </dev/null &
    pids="$pids $!"
  done

  panel_status=0
  for p in $pids; do
    if ! wait "$p"; then panel_status=1; fi
  done
  trap - INT TERM

  idx=0
  for a in $panel_agents; do
    idx=$((idx + 1))
    out="$paneldir/$(printf '%03d' "$idx")-$a.out"
    err="$paneldir/$(printf '%03d' "$idx")-$a.err"
    printf '\n===== %s =====\n\n' "$a"
    [ -f "$out" ] && cat "$out"
    [ -f "$err" ] && [ -s "$err" ] && cat "$err" >&2
  done
  printf '\n'

  rm -rf "$paneldir"
  [ -n "$panel_ctx_tmp" ] && rm -f "$panel_ctx_tmp"
  exit "$panel_status"
fi

# ----- prompt assembly -------------------------------------------------------

if [ "$raw" -eq 1 ]; then
  [ "$review" -eq 1 ] && warn "--review has no effect with --raw (raw sends the question verbatim); ignoring --review"
  prompt="$question"
  if [ -n "$stdin_content" ]; then
    prompt="$prompt

$stdin_content"
  fi
else
  if [ "$review" -eq 1 ]; then
    prompt="$REVIEW_PREAMBLE"
  else
    prompt="$PREAMBLE"
  fi
  if [ -n "$context_file" ]; then
    prompt="$prompt

## Context

$(cat "$context_file")"
  fi
  if [ -n "$stdin_content" ]; then
    prompt="$prompt

## Input

$stdin_content"
  fi
  prompt="$prompt

## Question

$question"
fi

# Agentic advisors (agy, grok) run a tool/exploration loop in headless mode and can
# end their turn with NO text (exit 0, empty stdout): agy's read-only `command` tool
# is auto-denied by the closed stdin — it then returns nothing — and grok wanders
# into file/web exploration. When NO working dir is attached, nudge just these two to
# answer from the given context as text. Skipped when --code IS given (the caller
# WANTS exploration — telling them not to explore would contradict --add-dir) and for
# --raw (the caller wants the question verbatim).
if [ "$raw" -eq 0 ] && [ -z "$code_dir" ]; then
  case "$agent" in
    agy|grok)
      prompt="$prompt

(Headless-mode note: reply with your written analysis as plain text, based on the
context and any working directory provided to you. Do NOT try to run shell commands
to explore — in this non-interactive session those tool calls are auto-denied and
you would return an empty answer instead of an analysis.)"
      ;;
  esac
fi

# ----- build the agent command ----------------------------------------------

cmd=("$(agent_bin "$agent")")
case "$agent" in
  claude)
    cmd+=(-p)
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$model" ] && cmd+=(--model "$model")
    [ -n "$code_dir" ] && cmd+=(--add-dir "$code_dir")
    cmd+=("$prompt")
    ;;
  agy)
    # agy reads the prompt as the positional that IMMEDIATELY follows -p. Any
    # flag placed between -p and the prompt (e.g. --add-dir) is parsed as the
    # request itself, so every flag must precede -p and the prompt must be the
    # final token. Verified: `agy --add-dir DIR -p "..."` answers correctly,
    # while `agy -p --add-dir DIR "..."` makes agy investigate "--add-dir".
    # Isolate agy from this machine's ~/.gemini/GEMINI.md (global agent
    # instructions: cheap-first / SSoT / [precision read]) so it answers as a
    # clean advisor instead of pursuing its own tool loop. Auth lives in the OS
    # keyring, so a GEMINI.md-free dir keeps login working. Verified:
    # `agy --gemini_dir=<clean> -p ...` -> auth OK, zero pollution.
    _agy_clean="${CONSILIUM_AGY_DIR:-$HOME/.consilium/agy-clean}"
    if [ ! -e "$_agy_clean/google_accounts.json" ]; then
      mkdir -p "$_agy_clean"
      ln -sf "$HOME/.gemini/google_accounts.json" "$_agy_clean/google_accounts.json" 2>/dev/null || true
      ln -sf "$HOME/.gemini/config" "$_agy_clean/config" 2>/dev/null || true
    fi
    cmd+=("--gemini_dir=$_agy_clean")
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$model" ] && cmd+=(--model "$model")
    # agy's file-exploration tools are auto-denied in headless mode (closed stdin
    # can't grant the permission), so a question that needs it often returns NOTHING
    # (measured: --code exploration questions came back empty 3/3, both retries too).
    # We still pass --add-dir (it sometimes answers from the workspace), but warn:
    # for agy, embed the slice via --context / a pipe, or use claude/codex for --code.
    if [ -n "$code_dir" ]; then
      warn "agy: --code exploration is unreliable headless (its file tools are auto-denied; it often returns nothing) — prefer --context or a pipe, or use claude/codex for --code reviews"
      cmd+=(--add-dir "$code_dir")
    fi
    cmd+=(-p "$prompt")
    ;;
  hermes)
    # Nous Research Hermes Agent: one-shot via `hermes chat -q "<prompt>"`.
    # All flags precede -q so the prompt is consumed as -q's value.
    cmd+=(chat)
    [ -n "$model" ] && cmd+=(--model "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$code_dir" ] && warn "hermes: --code is not supported (no --add-dir flag); ignoring"
    cmd+=(-q "$prompt")
    ;;
  opencode)
    cmd+=(run)
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$model" ] && cmd+=(-m "$model")
    [ -n "$code_dir" ] && warn "opencode: --code is not wired in the dispatch table; ignoring"
    cmd+=("$prompt")
    ;;
  codex)
    cmd+=(exec --sandbox read-only)
    [ "$do_continue" -eq 1 ] && warn "codex: --continue is not supported in exec mode; ignoring"
    [ -n "$model" ] && cmd+=(-m "$model")
    [ -n "$code_dir" ] && cmd+=(-C "$code_dir")
    cmd+=("$prompt")
    ;;
  grok)
    # xAI Grok CLI (superagent-ai/grok-cli): `-p`/`--single` takes the prompt as
    # its value, prints the answer to stdout, and exits (default output is plain
    # text). Flags verified against `grok --help`.
    [ -n "$model" ] && cmd+=(-m "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$code_dir" ] && cmd+=(--cwd "$code_dir")
    cmd+=(-p "$prompt")
    ;;
  pi)
    # Pi coding agent (pi.dev): print-and-exit. Docs say `-p`/`--print` is boolean
    # with the prompt as a trailing positional, but that is NOT verified against the
    # binary — so place `-p "$prompt"` LAST, which is correct whether -p is boolean
    # (prompt = positional) OR consumes the next token as its value (like grok's -p).
    [ -n "$model" ] && cmd+=(--model "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$code_dir" ] && warn "pi: no working-directory flag; --code ignored (cd into the dir before consulting)."
    cmd+=(-p "$prompt")
    ;;
  cursor)
    # Cursor CLI (binary `cursor-agent`, or a bare `agent` alias — see agent_bin):
    # `-p` is print mode but its output DEFAULTS to stream-json, so pin
    # `--output-format text` for a clean answer. Continue is `--resume` (there is
    # no --continue). Flags verified against `cursor-agent --help`. Advice-safe:
    # `-f`/--force is never passed, so a write/bash tool needs an approval the
    # closed stdin can't give.
    cmd+=(-p --output-format text)
    [ -n "$model" ] && cmd+=(--model "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(--resume)
    [ -n "$code_dir" ] && warn "cursor: no working-directory flag; --code ignored (cd into the dir before consulting)."
    cmd+=("$prompt")
    ;;
  kilo)
    # Kilo Code CLI: `kilo run "<msg>"` is non-interactive by default. We do NOT
    # pass --auto, so any write still hits a permission gate that the closed stdin
    # cannot approve — the advisor stays advice-only in practice.
    cmd+=(run)
    [ -n "$model" ] && cmd+=(-m "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$code_dir" ] && cmd+=(--dir "$code_dir")
    cmd+=("$prompt")
    ;;
  cline)
    # Cline CLI: goes headless because consilium always pipes/redirects the
    # advisor's stdout (the documented non-interactive trigger). Requires a prior
    # `cline auth`. Cline defaults to act mode with auto-approve, so it executes
    # tool calls WITHOUT prompting — the closed stdin does NOT stop it. Pass
    # `--auto-approve false` to force the approval gate the closed stdin then denies.
    # (Reviewers agy+hermes independently confirmed the default-auto-approve hole.)
    cmd+=(--auto-approve false)
    [ -n "$model" ] && cmd+=(-m "$model")
    [ -n "$code_dir" ] && cmd+=(--cwd "$code_dir")
    [ "$do_continue" -eq 1 ] && warn "cline: no documented continue/resume flag; ignoring --continue."
    cmd+=("$prompt")
    ;;
  goose)
    # Goose CLI (Block): `goose run -t "<prompt>"` executes and exits; `-q` keeps
    # stdout to just the model's answer. Goose runs tools AUTONOMOUSLY by default
    # (GOOSE_MODE=auto), so the closed stdin does NOT gate writes. Force
    # GOOSE_MODE=approve UNCONDITIONALLY so any tool call needs an approval the
    # closed stdin denies — a preset GOOSE_MODE=auto is deliberately overridden,
    # because the tool's contract is read-only advice. Reviewers agy+hermes flagged
    # the autonomy.
    export GOOSE_MODE=approve
    cmd+=(run -q)
    [ -n "$model" ] && cmd+=(--model "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(-r)
    [ -n "$code_dir" ] && warn "goose: 'run' has no working-directory flag; --code ignored (cd into the dir before consulting)."
    cmd+=(-t "$prompt")
    ;;
  kimi)
    # Kimi Code CLI (Moonshot AI, binary `kimi`): `-p/--prompt <prompt>` runs one
    # prompt non-interactively, prints the answer, and exits. The prompt is -p's
    # VALUE, so every flag precedes it and the prompt is the final token. Output
    # defaults to text (no --output-format pin needed, unlike cursor). Working dir
    # is passed with --add-dir (like claude/agy). Advice-safe: neither -y/--yolo
    # nor --auto is passed, so approval mode stays interactive and any write/tool
    # call hits a gate the closed stdin cannot approve. Verified against
    # `kimi --help` + a live `kimi -p` probe on v0.27.0 (exit 0, answer on stdout;
    # its reasoning trace and session-resume hint go to stderr, not the answer).
    [ -n "$model" ] && cmd+=(-m "$model")
    [ "$do_continue" -eq 1 ] && cmd+=(-c)
    [ -n "$code_dir" ] && cmd+=(--add-dir "$code_dir")
    cmd+=(-p "$prompt")
    ;;
esac

# ----- optional timeout wrapper ---------------------------------------------

runner=()
if [ -n "${CONSILIUM_TIMEOUT:-}" ]; then
  case "$CONSILIUM_TIMEOUT" in
    *[!0-9]*|"") warn "CONSILIUM_TIMEOUT must be a whole number of seconds; ignoring" ;;
    *)
      if command -v timeout >/dev/null 2>&1; then
        runner=(timeout -k 10 "$CONSILIUM_TIMEOUT")
      elif command -v gtimeout >/dev/null 2>&1; then
        runner=(gtimeout -k 10 "$CONSILIUM_TIMEOUT")
      elif command -v perl >/dev/null 2>&1; then
        # Stock macOS has no GNU coreutils. A tiny perl runner gives the SAME
        # bound: it setsid()s the advisor into its own process group, and on
        # timeout SIGTERMs then (after a grace) SIGKILLs the WHOLE group, exiting
        # 124 — so a hung or orphaned paid advisor cannot run forever. It also
        # forwards INT/TERM to that group, so Ctrl-C and the panel trap still kill it.
        runner=(perl -e 'use POSIX qw(setsid); use Errno qw(EINTR); my $t = shift @ARGV; my $ka = 10;
exit(127) unless @ARGV;
my $pid = fork(); exit(127) unless defined $pid;
if ($pid == 0) { setsid(); exec { $ARGV[0] } @ARGV; POSIX::_exit(127); }
my $s = 0; my $to = 0;
$SIG{ALRM} = sub { if ($s == 0) { $s = 1; $to = 1; kill(q{TERM}, -$pid); alarm($ka); } else { kill(q{KILL}, -$pid); } };
$SIG{TERM} = sub { kill(q{TERM}, -$pid); if ($s == 0) { $s = 1; alarm($ka); } };
$SIG{INT}  = sub { kill(q{INT},  -$pid); if ($s == 0) { $s = 1; alarm($ka); } };
alarm($t) if $t > 0;
my $st = 0;
while (1) { my $r = waitpid($pid, 0); if ($r == $pid) { $st = $?; last; } last if ($r == -1 && $! != EINTR); }
alarm(0);
exit(124) if $to;
exit(128 + ($st & 127)) if ($st & 127);
exit($st >> 8);' -- "$CONSILIUM_TIMEOUT")
      else
        warn "CONSILIUM_TIMEOUT set but no 'timeout'/'gtimeout'/'perl' found; running without it"
      fi
      ;;
  esac
fi

# ----- run, retry-on-empty, print, and log -----------------------------------
# The advisor is spawned as a child process, so it inherits THIS working
# directory. That is deliberate: it shares our cwd-scoped context — tqmemory keys
# memory by cwd, and project AGENTS.md/GEMINI.md/CLAUDE.md resolve from here.
#
# Agentic advisors (notably agy and grok) intermittently end their headless turn
# without emitting any text — exit 0, empty stdout — when a tool call is auto-denied
# (closed stdin) or the exploration loop wanders off. Retry on EXACTLY that
# signature (clean exit + whitespace-only answer); never retry a real error or a
# timeout (status != 0), which would just fail again. CONSILIUM_RETRY_EMPTY tunes
# it (default 1; 0 disables).
retries="${CONSILIUM_RETRY_EMPTY:-1}"
case "$retries" in *[!0-9]*|"") retries=1 ;; esac

# true when FILE holds no non-whitespace byte (the empty-answer signature).
answer_is_blank() { ! LC_ALL=C grep -q '[^[:space:]]' "$1" 2>/dev/null; }

tmp="$(mktemp "${TMPDIR:-/tmp}/consilium.XXXXXX")"
status=0
tee_status=0
attempt=0
while : ; do
  : > "$tmp"
  # Snapshot PIPESTATUS in one step right after the pipe: any later command resets
  # it, and reading [1] afterwards would be an unbound-variable abort under set -u.
  set +e
  "${runner[@]+"${runner[@]}"}" "${cmd[@]}" </dev/null | tee "$tmp"
  pipe_status=("${PIPESTATUS[@]}")
  set -e
  status=${pipe_status[0]}
  tee_status=${pipe_status[1]:-0}
  if [ "$status" -eq 0 ] && answer_is_blank "$tmp" && [ "$attempt" -lt "$retries" ]; then
    attempt=$((attempt + 1))
    warn "advisor '$agent' exited 0 with an empty answer; retrying ($attempt/$retries)…"
    continue
  fi
  break
done

# tee can fail (disk full, no write perm) while the advisor itself succeeded.
if [ "$tee_status" -ne 0 ]; then
  warn "could not capture the answer (tee exit $tee_status); a transcript may be truncated"
fi
# Still blank after exhausting retries: surface it AND fail (exit 4) so an empty
# reply is not mistaken for a real (short) answer — a bare exit 0 would let a caller,
# or a --panel parent, treat "no answer" as success.
if [ "$status" -eq 0 ] && answer_is_blank "$tmp"; then
  warn "advisor '$agent' returned no answer after $((attempt + 1)) attempt(s) — agy/grok are agentic CLIs whose headless turn can end without text; retry, raise CONSILIUM_TIMEOUT, or use a non-agentic advisor (claude/codex/hermes)"
  status=4
fi

if [ "$no_log" -eq 1 ]; then
  rm -f "$tmp"
  exit "$status"
fi

# Transcripts contain the FULL prompt (question + any --context + piped diff), so
# keep them owner-private (umask 077 -> dir 700, file 600) instead of the default
# 022 that leaves them readable by other local users. chmod the dir too, so an
# ALREADY-existing log dir (created before this fix) is tightened as well.
( umask 077; mkdir -p "$LOG_DIR" )
chmod 700 "$LOG_DIR" 2>/dev/null || true
ts="$(date +%Y%m%d-%H%M%S)"
logfile="$LOG_DIR/${ts}-${agent}-$$.md"

( umask 077
  {
    printf '# consilium consult — %s — %s\n\n' "$agent" "$ts"
    [ "$attempt" -gt 0 ] && printf '> note: the advisor returned an empty answer on %s earlier attempt(s) before this one.\n\n' "$attempt"
    printf '## Prompt\n\n```\n%s\n```\n\n' "$prompt"
    printf '## Answer\n\n'
    cat "$tmp"
    printf '\n'
  } > "$logfile"
)

rm -f "$tmp"
printf '\n[consilium] transcript: %s\n' "$logfile" >&2

# prune old transcripts so the log directory doesn't grow forever
keep="${CONSILIUM_LOG_KEEP:-200}"
case "$keep" in *[!0-9]*|"") keep=200 ;; esac
if [ "$keep" -gt 0 ]; then
  ls -t "$LOG_DIR"/*.md 2>/dev/null | tail -n +"$((keep + 1))" | while IFS= read -r old; do rm -f "$old"; done
fi

exit "$status"
